DB_USER=root
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_name

# Railway MySQL (auto-injected when you link a MySQL service):
# MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE
# or DATABASE_URL / MYSQL_URL

JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=1440

# Admin seeder only — never use these in public registration
ADMIN_EMAIL=admin@localjobs.test
ADMIN_PASSWORD=Admin_password
ADMIN_FULL_NAME=Platform Admin

FLASK_DEBUG=1

# Comma-separated browser origins allowed to call the API directly (Option B client setup)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://hirehub-client-git-main-shanujan-ts-projects.vercel.app/api

# Twilio WhatsApp sandbox (optional — demo logs to console when unset)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
